# Shared by FastAPI and the Next.js inference proxy
INFERENCE_API_SECRET=YOUR_SECRET_KEY

# Discord bot
TOKEN = YOUR_DISCORD_BOT_TOKEN

# YouTube API
API_KEY = YOUR_YOUTUBE_API

# Ollama
OLLAMA_HOST=http://host.docker.internal:11434 # host.docker.internal | localhost
OLLAMA_MODEL=gemma4:12b # gemma4:12b | llama3.2:3b
OLLAMA_KEEP_ALIVE=30m
# auto: llama3.2:3b -> 8192 context, gemma4:12b -> 12000 context
OLLAMA_PROFILE=auto # auto | small | large | standard
# Optional manual overrides
# OLLAMA_NUM_CTX=8192
# OLLAMA_MAX_NUM_PREDICT=2200
# VIDEO_TRANSCRIPT_CHUNK_CHARS=6000

# Whisper 
WHISPER_MODEL_SIZE=small # base | small | medium | large
WHISPER_BATCH_SIZE=16
WHISPER_BEAM_SIZE=8
WHISPER_PATIENCE=1.2
WHISPER_CONDITION_ON_PREVIOUS_TEXT=True
WHISPER_UNLOAD_OLLAMA_BEFORE_TRANSCRIBE=True
WHISPER_RELEASE_MODEL_AFTER_TRANSCRIBE=True
